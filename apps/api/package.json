{
    "name": "api",
    "type": "module",
    "scripts": {
        "dev": "bun --no-clear-screen --env-file=../../.env src/index.ts",
        "typecheck": "tsc --noEmit",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "compile": "bun build src/index.ts --compile --outfile ./server",
        "start": "NODE_ENV=production bun dist/index.js",
        "test": "bun test",
        "demo": "bun --env-file=../../.env.demo demo/index.ts",
        "generate": "drizzle-kit generate",
        "migrate": "drizzle-kit migrate",
        "studio": "drizzle-kit studio",
        "lint": "prettier --check . && eslint .",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.100.1",
        "@gitbeaker/rest": "^43.8.0",
        "@octokit/app": "^16.1.2",
        "@octokit/rest": "^22.0.1",
        "@proval/db": "workspace:*",
        "@proval/types": "workspace:*",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.12.7",
        "openai": "^4.100.0",
        "picocolors": "^1.1.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@proval/config": "workspace:*",
        "@types/bun": "^1.3.11",
        "drizzle-kit": "^0.31.9",
        "eslint": "^9.39.2",
        "prettier": "^3.8.1",
        "typescript": "^5.8.3"
    }
}
