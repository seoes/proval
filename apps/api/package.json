{
    "name": "api",
    "type": "module",
    "scripts": {
        "dev": "bun --watch --env-file=.env src/index.ts",
        "typecheck": "tsc --noEmit",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "compile": "bun build src/index.ts --compile --outfile ./server",
        "start": "NODE_ENV=production bun dist/index.js",
        "test": "bun test",
        "demo": "bun --env-file=.env.demo demo/index.ts",
        "generate": "drizzle-kit generate",
        "migrate": "drizzle-kit migrate",
        "studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@code-review/db": "workspace:*",
        "@code-review/types": "workspace:*",
        "@gitbeaker/rest": "^43.8.0",
        "@octokit/app": "^16.1.2",
        "@octokit/rest": "^22.0.1",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.12.7",
        "openai": "^4.100.0",
        "picocolors": "^1.1.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "drizzle-kit": "^0.31.9",
        "typescript": "^5.8.3"
    }
}
