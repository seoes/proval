{
    "name": "proval",
    "version": "1.0.0",
    "license": "AGPL-3.0",
    "packageManager": "bun@1.3.11",
    "scripts": {
        "dev": "FORCE_COLOR=1 bun run --parallel --filter '*' dev",
        "build": "bun run --parallel --filter '*' build",
        "test": "bun run --parallel --filter '*' test",
        "lint": "bun run --parallel --filter '*' --filter '!@proval/config' lint",
        "format": "bun run --parallel --filter '*' --filter '!@proval/config' format",
        "tunnel": "cloudflared tunnel run proval-dev",
        "tunnel:tmp": "cloudflared tunnel --url http://localhost:7901",
        "studio": "bun run --filter 'api' studio",
        "generate": "bun run --filter 'api' generate",
        "migrate": "bun run --filter 'api' migrate"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ]
}
